# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# API (Node)
PORT=3001
API_PUBLIC_URL=http://localhost:3001
PUBLIC_WEB_URL=http://localhost:5173
APP_ENCRYPTION_KEY=replace_with_32_plus_char_secret_string_minimum

# Optional: Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: marketplaces
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=https://YOUR_NGROK_OR_LOCAL/oauth/ebay/callback
EBAY_SANDBOX=true
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Optional: AI (Google Gemini — free tier available at https://aistudio.google.com/)
GEMINI_API_KEY=

# Browser (Vite) — same values as SUPABASE_* above; required for the web app. Must use VITE_ prefix.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
